# ──────────────────────────────────────
# TLS / HTTPS
# ──────────────────────────────────────
SSL_CERTFILE=infra/certs/cert.pem
SSL_KEYFILE=infra/certs/key.pem

# ──────────────────────────────────────
# JWT Authentication
# ──────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ──────────────────────────────────────
# Elasticsearch
# ──────────────────────────────────────
ES_HOST=localhost
ES_PORT=9200
ES_INDEX_LOGS=siem-logs
ES_INDEX_USERS=siem-users
ES_INDEX_AUDIT=siem-audit
ES_INDEX_ALERTS=siem-alerts

# ──────────────────────────────────────
# Retention Policy
# ──────────────────────────────────────
RETENTION_DAYS=30

# ──────────────────────────────────────
# API
# ──────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=443