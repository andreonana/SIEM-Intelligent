# ============================================================
# Smart SIEM — Configuration partagée (racine du projet)
# Lu par le backend (pydantic-settings) ET docker-compose
#
# Copier ce fichier vers .env puis remplacer TOUTES les valeurs
# marquées [À REMPLACER] avant tout déploiement.
# ============================================================

# ──────────────────────────────────────
# Elasticsearch
# En local (hors Docker) : http://localhost:9200
# En Docker Compose      : http://elasticsearch:9200
# ──────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme        # [À REMPLACER]
ELASTICSEARCH_CA_CERT_PATH=

ES_LOGS_INDEX_NAME=smart-siem-logs
ES_AUDIT_INDEX_NAME=smart-siem-audit

# ──────────────────────────────────────
# JWT Authentication
# Générer : python3 -c "import secrets; print(secrets.token_hex(32))"
# ──────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string-minimum-32-chars   # [À REMPLACER]
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ──────────────────────────────────────
# Ingestion API key (header X-API-Key requis sur /ingest)
# Générer : python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# ──────────────────────────────────────
INGEST_API_KEY=replace-with-a-random-key      # [À REMPLACER]

# ──────────────────────────────────────
# Base de données relationnelle (utilisateurs, audit)
# PostgreSQL (production) :
#   DATABASE_URL=postgresql+asyncpg://siem:<motdepasse>@localhost:5432/siem_db
# SQLite (développement local / CI) :
# ──────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./siem.db

# ──────────────────────────────────────
# Rétention des logs (en jours)
# ──────────────────────────────────────
RETENTION_DAYS=30
ENABLE_RETENTION_SCHEDULER=true

# ──────────────────────────────────────
# Rate limiting ingestion
# ──────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60

# ──────────────────────────────────────
# Forwarder agent (logs → backend)
# ──────────────────────────────────────
BACKEND_URL=http://localhost:8000
BATCH_SIZE=50
POLL_INTERVAL=2

# ──────────────────────────────────────
# TLS — Nginx frontal
# Générer les certificats avant le premier démarrage :
#   bash infra/tls/generate-certs.sh
# ──────────────────────────────────────

# ──────────────────────────────────────
# Notifications (Slack, Teams, Email)
# Si une variable est vide, le canal correspondant est ignoré sans erreur.
# ──────────────────────────────────────
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# ──────────────────────────────────────
# SOAR — Firewall Controller
#
# Service réel (voir infra/firewall-controller/) qui exécute iptables pour
# bloquer une IP à la demande du playbook SOAR `block_ip`. Contrat HTTP :
#   POST /block   {"ip": "...", "reason": "..."}
#     → 200 {"status": "blocked", "ip": "..."}
#     → 200 {"status": "failure", "ip": "...", "error": "..."}
#
# Sans cette variable configurée, block_ip échoue explicitement
# (status=failure) — il ne simule jamais un blocage.
#
# En Docker Compose, le nom "firewall-controller" résout via le DNS interne
# du réseau siem-net (service défini dans docker-compose.yml).
# ──────────────────────────────────────
FIREWALL_API_URL=http://firewall-controller:8080
